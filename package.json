{
  "name": "review-mark",
  "version": "1.1.0",
  "description": "A CLI tool for AI-powered code review using git diff.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "review-mark": "dist/cli/review.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/review.js",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ai",
    "code-review",
    "cli",
    "git",
    "diff",
    "cursor",
    "feishu"
  ],
  "author": "snowmountain-top",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowmountain-top/review-mark.git"
  },
  "homepage": "https://github.com/snowmountain-top/review-mark#readme",
  "bugs": {
    "url": "https://github.com/snowmountain-top/review-mark/issues"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "commander": "^12.0.0"
  }
}
